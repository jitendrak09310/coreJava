package oops;

public class DataTypeVariableOperators {
	public static void main(String[] args) {
		int a = 5, b = 2;
		System.out.println(a / b);
		System.out.println(a % b);

		byte c = 127;
		c++;
		System.out.println(c);

		int x = 10;
		int y = x++;

		System.out.println(x + " " + y);

		x = 10;
		y = ++x;

		System.out.println(x + " " + y);

		double d = 1.0 / 0;

		System.out.println(d);
		x = 5;
		System.out.println(x << 1);
		System.out.println(x >> 1);
		System.out.println(x >>> 1);

		a = 6;
		b = 3;

		System.out.println(a & b);
		System.out.println(a | b);
		System.out.println(a ^ b);
		System.out.println(~a);
	}

}
