package interfaceAbstraction;

public class Area {

	public static void main(String[] args) {
		
	}

}

abstract class Shape {
	abstract double area();

	void display() {
		System.out.printf("Area: %.2f%n", area());
	}
}

class Circle extends Shape {
	double r;

	Circle(double r) {
		this.r = r;
	}

	@Override
	double area() {
		return Math.PI * r * r;

	}

}