package arrays;

public class TrappedWater {

	public static void main(String[] args) {

		int arr[] = { 4, 2, 0, 6, 3, 2, 5 };

		calculateTrappedWater(arr);

	}

	public static int calculateTrappedWater(int[] arr) {
		int n = arr.length;
		int tw = 0;
		// tw = (wl-currentLevel )*width;
		// water level == will be min value of left max and right max for that current

		// we will have to create two helper arrays leftmax and right to get the max
		// value at certain positions

		int[] lm = new int[n];
		int[] rm = new int[n];
		lm[0] = arr[0];

		for (int i = 1; i < n; i++) {
			lm[i] = Math.max(lm[i], lm[i - 1]);
		}

		rm[n] = arr[n];
		for (int i = n - 1; i >= 0; i--) {
			rm[i] = Math.max(rm[i], rm[i + 1]);
		}

		return tw;
	}

}
