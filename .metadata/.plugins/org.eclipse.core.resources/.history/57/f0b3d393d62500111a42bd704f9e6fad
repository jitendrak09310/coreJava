package arrays;

public class FindIndexInSortedRotated {

	public static void main(String[] args) {
		int target = 0;
		int[] nums = { 4, 5, 6, 7, 0, 1, 2 };
		int index = findIndex(nums, target);
		System.out.println(index);
	}

	public static int findIndex(int[] nums, int target) {

		int n = nums.length;

		int left = 0;
		int right = n - 1;

		while (left <= right) {

			int mid = left + (right - left) / 2; // this is used to avoid the int overflow. 

			if (nums[mid] == target) {
				return mid;
			}

			if (nums[left] <= nums[mid]) {
				if (target >= nums[left] && target <= nums[mid]) { // checking the left half.
					right = mid - 1;
				} else {
					left = mid + 1;
				}

			} else {
				if (target >= nums[mid] && target <= nums[right]) { //checking the right half
					left = mid + 1;
				} else {
					right = mid - 1;
				}
			}

		}

		return -1;
	}
}
