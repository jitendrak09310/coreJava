package arrays;

import java.util.Arrays;

public class BubbleSort {

	public static void main(String[] args) {

		int nums[] = { 5, 3, 1, 2, 4 };
		int[] res = bubbleSorting(nums);
		System.out.println(Arrays.toString(res));
	}

	public static int[] bubbleSorting(int nums[]) {
		int n = nums.length;

		for (int i = 0; i < n-1; i++) {
			for (int j = 0; j < n - i; j++) {
				if (nums[j] > nums[j + 1]) {
					int temp = nums[j];
					nums[j] = nums[j + 1];
					nums[j + 1] = temp;
				}
			}
		}
		return nums;
	}
}
