package java8;

import java.util.stream.Stream;

public class Test6 {

	public static void main(String[] args) {
		long count = Stream.iterate(1, n -> n + 1).limit(10).filter(n -> n % 3 == 0).count();
		System.out.println(count);
		
		
		Integer product = Stream.iterate(1,  n->n+1)
		.limit(5)
		.reduce(1,(a,b)->a*b);
		System.out.println(product);
	}

}
