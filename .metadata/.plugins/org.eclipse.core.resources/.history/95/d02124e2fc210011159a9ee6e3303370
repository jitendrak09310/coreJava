package controlFlow;

public class ControlFlow {

	public static void main(String[] args) {
		for (int i = 0; i < 5; i++) {
			if (i == 3)
				break;
			System.out.println(i + " ");
		}
		System.out.println("*******************************************");
		for (int i = 0; i < 5; i++) {
			if (i == 3)
				continue;
			System.out.println(i + " ");
		}
		int i = 5;
		do {
			System.out.println(i + " ");
			i--;
		} while (i > 7);

		// Switch statements..

		int x = 10;

		switch (x) {
		case 1: {
			System.out.println();
			break;

		}
		case 10: {
			System.out.println("Value is... " + x);
			break;
		}
		default:
			throw new IllegalArgumentException("Unexpected value: " + x);
		}

		System.out.println("***************************");
		// nested Loops ...

		outer: for (int k = 0; k < 3; k++) {
			for (int j = 0; j < 3; j++) {
				if (j == 1) {
					break outer;
				}
				System.out.println(i + " " + k + " ");
			}
		}
		System.out.println("***************************");
		int p = 0, sum = 0;

		outer: while (p < 4) {
			p++;
			int j = 0;
			while (j < 4) {
				j++;
				if (p + j == 5) {
					continue outer;

				}
				sum += p + j;
			}
		}

		System.out.println(sum);

		System.out.println("***************************");

		String day = "SAT";

		int result = switch (day) {
		case "MON", "TUE", "WED", "THURS", "FRI" -> 1;
		case "SAT", "SUN" -> 2;
		default -> 0;

		};
		System.out.println(result);

	}

}
