package arrays;

public class MaxProfit {

	public static void main(String[] args) {
		int prices[] = { 7, 1, 5, 3, 6, 4 };

		int maxProfit = calMaxProfit(prices);
		System.out.println(maxProfit);
	}

	public static int calMaxProfit(int arr[]) {

		int maxProfit = 0;
		int cbp = Integer.MAX_VALUE;
		for (int i = 0; i < arr.length; i++) {
			if (cbp < arr[i]) {
				cbp = arr[i];
			}
			int cp = arr[i] - cbp;
			maxProfit = Math.max(maxProfit, cp);

		}

		return maxProfit;
	}
}
