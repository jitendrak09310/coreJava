package twoPointer;

public class SortColors {

	public static void main(String[] args) {
		int nums[] = { 2, 0, 2, 1, 1, 0 };

		int n = nums.length;
		int l = 0;
		int m = 0;
		int h = n - 1;

		while (m <= h) {
			if (nums[m] == 0) {
				int temp = nums[l];
				nums[l] = nums[m];
				nums[m] = temp;
				l++;
				m++;
			} else if (nums[m] == 1) {
				m++;
			} else if (nums[m] == 2) {
				int temp = nums[m];
				nums[m] = nums[h];
				nums[h] = temp;
				h--;
			}
		}

		for (int i : nums) {
			System.out.println(i);
		}
	}

}
