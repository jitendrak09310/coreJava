package arrays;

import java.util.Currency;

public class MaxSubarraySum {

	public static void main(String[] args) {
		int arr[] = { 1, 13, 4, 5, 7 };
		int maxSubArraySumBruteForce = maxSubArraySumBruteForce(arr);
		System.out.println(maxSubArraySumBruteForce);

		maxSubArraySumWithPrefix(arr);
	}

	public static int maxSubArraySumWithPrefix(int[] arr) {
		int n = arr.length;
		int maxSum = Integer.MIN_VALUE;
		int[] prefixArray = new int[arr.length];
		prefixArray[0] = arr[0];
		for (int i = 1; i < arr.length; i++) {
			prefixArray[i] = arr[i] + prefixArray[i - 1];
		}

		for (int i = 0; i < n; i++) {
			for (int j = i; j < n; j++) {
				int currsum = i == 0 ? prefixArray[j] : prefixArray[i] - prefixArray[j - 1];
				Math.max(maxSum, currsum);
			}

		}
		return maxSum;
	}

	public static int maxSubArraySumBruteForce(int arr[]) {
		int maxSum = Integer.MIN_VALUE;
		int n = arr.length;
		for (int i = 0; i < n; i++) {
			for (int j = i; j < n; j++) {
				int currSum = 0;
				for (int k = i; k <= j; k++) {
					currSum += arr[k];
				}
				maxSum = Math.max(maxSum, currSum);
			}
		}
		return maxSum;
	}
}
