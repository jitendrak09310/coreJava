package interfaceAbstraction;

public class Area {

}

abstract class Shape {
	abstract double area();

	void display() {
		System.out.printf("Area: %.2f%n", area());
	}
}

class Circle extends Shape {
	double r;

	Circle(double r) {
		this.r = r;
	}

	@Override
	double area() {

		// TODO Auto-generated method stub
		return Math.PI * r * r;

	}

}