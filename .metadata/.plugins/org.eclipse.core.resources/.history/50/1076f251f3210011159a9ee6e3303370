package stringOperations;

public class StringOperations {

	public static void main(String[] args) {
		String s1 = "Hello";
		String s2 = "Hello";

		String s3 = new String("Hello");
		String s4 = new String("Hello");

		System.out.println(s1 == s2);
		System.out.println(s1.equals(s2));

		System.out.println(s3 == s4);
		System.out.println(s3.equals(s4));

		String s = "Java";
		s.concat("Prgramming");// String Immutability
		System.out.println(s);

		System.out.println("5" + 3 + 2);
		System.out.println(3 + 2 + "5");
		System.out.println("1" + (2 + 3));

		s = "Hello World";

		System.out.println(s.substring(6));

		System.out.println(s.substring(0, 5));
		System.out.println(s.indexOf('o'));
		System.out.println(s.lastIndexOf('o'));

		s = "abcabc";
		System.out.println(s.replace('a', 'x'));
		System.out.println(s.replaceFirst("a", "x"));
		System.out.println(s.toUpperCase());
		System.out.println(s);// same value string are immutable. ..

		StringBuilder sb = new StringBuilder("Hello");
		sb.reverse().append("!").insert(0, ">>>");

		System.out.println(sb);
		System.out.println(sb.length()); // string builder is mutable. ..

		s = "  Hello World ";
		System.out.println(s.trim().length());
		System.out.println(s.strip().length());
		System.out.println(s.isBlank());
		System.out.println(" ".isBlank());

		s = "Java";
		System.out.println(s.intern() == "Java");
		String intern = new String("Java").intern(); // intern() ensures that a String is stored in the String pool and
														// returns a reference from that pool.
		System.out.println(intern == "Java");

		String tr = String.format("%-10s|%5d|%.2f", "Hi", 42, 3.14159);
		// %-10s --> it left allign to 10 chars.
		// %5d -- > right allign in in 5 chars
		// %2f --> float with 2 decimal...
		
		
		System.out.println(tr);

	}

}
