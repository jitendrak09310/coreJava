package arrays;

public class PrintSubArrays {

	public static void main(String[] args) {
		int arr[] = { 1, 13, 4, 5, 7 };

		printSubArrays(arr);
	}

	public static void printSubArrays(int[] arr) {

		int n = arr.length;
		for (int i = 0; i < n; i++) {
			for (int j = i; j < n; j++) {
				for (int k = i; k < j; k++) {
					System.out.print(k + " ");
				}
				System.out.println();
			}
		}

	}
}
