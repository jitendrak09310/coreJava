package arrays;

public class BinarySearchKey {

	public static void main(String[] args) {
		int arr[] = { 1, 4, 5, 6, 7, 13, 15, 16 };// array should be sorted for binary search..
		int key = 15;
		findKey(arr, key);

	}

	public static int findKey(int[] arr, int key) {

		int start = 0;
		int end = arr.length - 1;

		while (start < end) {
			int mid = (start + end) / 2;
			if (arr[mid] == key) {
				return mid;
			}
			if (arr[mid] < key) {
				return mid;
			}
			if (arr[mid] > key) {
				return mid;
			}
		}
		return -1;
	}

}
