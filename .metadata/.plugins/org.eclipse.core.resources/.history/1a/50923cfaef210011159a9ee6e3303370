package oops;

public class DataTypeVariableOperators {
	public static void main(String[] args) {
		int a = 5, b = 2;
		System.out.println(a / b);
		System.out.println(a % b);

		byte c = 127;
		c++;
		System.out.println(c);

		int x = 10;
		int y = x++;

		System.out.println(x + " " + y);

		x = 10;
		y = ++x;

		System.out.println(x + " " + y);

		double d = 1.0 / 0;

		System.out.println(d);
		x = 5;
		System.out.println(x << 1);
		System.out.println(x >> 1);
		System.out.println(x >>> 1);

		a = 6;
		b = 3;
// this is binary operation. 
		System.out.println(a & b);// AND
		System.out.println(a | b);// OR
		System.out.println(a ^ b);// XOR
		System.out.println(~a);// Bitwise Not

		x = 5;
		x += x -= x *= x;
		System.out.println(x);// calculate from right to left..

		System.out.println(0.1 + 0.2 == 0.3);// false because there is tin rounding error. here. Always use big decimal
												// for decimal values.
		System.out.println(0.1 + 0.2);

		long l = 2147483648L;
		int i = (int) l;
		System.out.println(i);
		
		int maxValue = Integer.MAX_VALUE;
		System.out.println(maxValue+1);

	}

}
