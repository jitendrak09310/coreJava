package multithreadingAndConcurrency;

public class Test4 {

	public static void main(String[] args) {

		static volatile boolean flag = false;
		Thread t = new Thread(() -> {
			while (!flag) {
				System.out.println("Flag seen!");
			}
		});
		t.start();
		Thread.sleep(100);
		flag = true;
		t.join();
		System.out.println("Done");
	}

}
