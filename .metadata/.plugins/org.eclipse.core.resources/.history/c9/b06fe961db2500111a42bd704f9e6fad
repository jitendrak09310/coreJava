package arrays;

public class TrappedWaterPractice {

	public static void main(String[] args) {
		int height[] = { 0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1 };
		int width = 1;
		int trappedWater = calTrappedWater(height, width);
		System.out.println(trappedWater);
	}

	public static int calTrappedWater(int height[], int width) {
		// int trapped water = wl(math.min (lm,rm) -current height)* width;
		int trappedWater = 0;
		int n = height.length;

		int[] lm = new int[n];
		lm[0] = height[0];
		for (int i = 1; i < n; i++) {
			lm[i] = Math.max(height[i], lm[i - 1]);
		}
		int[] rm = new int[n];

		rm[n - 1] = height[n - 1];
		for (int i = n - 2; i >= 0; i--) {
			rm[i] = Math.max(height[i], height[i + 1]);
		}

		for (int i = 0; i < n; i++) {
			int wl = Math.min(rm[i], lm[i]);
			trappedWater += (wl - height[i]) * width;
		}

		return trappedWater;
	}

}
