package interfaceAbstraction;

public class MoreSpecific implements D, E {
	
	public static void main(String[] args) {
		new MoreSpecific().print();
	}

}

interface D {
	default void print() {
		System.out.println("D");
	}
}

interface E extends D {
	default void print() {
		System.out.println("E");
	}
}
