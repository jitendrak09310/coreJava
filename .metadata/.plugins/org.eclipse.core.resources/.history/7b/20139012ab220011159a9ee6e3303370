package enums;

enum Operation {
	ADD {
		int apply(int a, int b) {
			return a + b;
		}
	},
	SUB {
		int apply(int a, int b) {
			return a - b;
		}

	},
	MUL {
		int apply(int a, int b) {
			return a * b;
		}
	}
}

public class Test1 {
	
	public static void main(String[] args) {
		System.out.println(Operation.ADD.apply(3,4));
	}

}


