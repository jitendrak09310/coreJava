package oops;

public class VariableWithMethodCalling {

	public static void main(String[] args) {

	}

	class A {
		int x = 10;

		A() {
			show();
		}

		void show() {
			System.out.println("A.show() : " + x);
		}
	}

	class B extends A {
		int x = 20;

		void show() {
			System.out.println("B.show : " + x);
		}
	}

}
