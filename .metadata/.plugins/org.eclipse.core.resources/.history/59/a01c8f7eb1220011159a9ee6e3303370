package recursion;

public class Test2 {

	public static void main(String[] args) {

		String s = "Jitendra";
		System.out.println(s.substring(1) + s.charAt(0));// adding the char at 0 at the end...
		System.out.println(reverse("Java"));
		System.out.println();

	}

	static String reverse(String s) {
		if (s.isEmpty()) {
			return s;
		}
		return reverse(s.substring(1) + s.charAt(0));
	}
}
