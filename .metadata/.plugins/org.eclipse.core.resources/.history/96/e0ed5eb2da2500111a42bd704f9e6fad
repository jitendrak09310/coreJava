package arrays;

public class TrappedWaterPractice {

	public static void main(String[] args) {
		int height[] = { 0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1 };
		calTrappedWater(height);
	}

	public static int calTrappedWater(int height[]) {
		// int trapped water = wl(math.min (lm,rm) -current height)* width;

		int n = height.length;

		int[] lm = new int[n];
		lm[0] = height[0];
		for (int i = 1; i < n; i++) {
			lm[i] = Math.max(height[i], height[i - 1]);
		}
		int[] rm = new int[n];

		rm[n - 1] = height[n - 1];
		for (int i = n - 2; i >= 0; i++) {
			rm[i] = Math.max(height[i - 1], height[i + 1]);
		}

		return 0;
	}

}
